generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  createdAt DateTime      @default(now())
  password  UserPassword?
}

model UserPassword {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
